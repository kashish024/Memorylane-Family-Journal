// firestore.rules
// Updated Firebase Security Rules for Contributors Feature

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user has access to a child
    function hasChildAccess(childId) {
      // Check if user is owner or contributor
      return get(/databases/$(database)/documents/children/$(childId)).data.ownerId == request.auth.uid ||
             (get(/databases/$(database)/documents/children/$(childId)).data.contributors != null && 
              get(/databases/$(database)/documents/children/$(childId)).data.contributors.hasAny([request.auth.uid]));
    }
    
    // Children collection
    match /children/{childId} {
      // Allow read for authenticated users (needed for invitation acceptance flow)
      // Note: Child documents contain basic info (name, avatar). All write operations
      // (update/delete) are still protected by rules below.
      allow read: if request.auth != null;
      
      // Only authenticated users can create children (they become owner)
      allow create: if request.auth != null &&
                      request.resource.data.ownerId == request.auth.uid;
      
      // Owner can update child details, or user can add/remove themselves as contributor
      allow update: if request.auth != null && (
                      // Owner can update anything
                      resource.data.ownerId == request.auth.uid ||
                      // User can add themselves as contributor when accepting invitation
                      // Check: new contributors array contains all old contributors plus current user
                      // and other critical fields remain unchanged
                      (request.resource.data.contributors != null &&
                       request.resource.data.contributors.hasAny([request.auth.uid]) &&
                       // If old contributors exist, new must contain all old ones
                       (resource.data.contributors == null ||
                        request.resource.data.contributors.hasAll(resource.data.contributors)) &&
                       request.resource.data.ownerId == resource.data.ownerId &&
                       request.resource.data.name == resource.data.name &&
                       request.resource.data.avatar == resource.data.avatar) ||
                      // User can remove themselves as contributor
                      // Check: old contributors array contains current user, new array doesn't
                      // and other critical fields remain unchanged
                      (resource.data.contributors != null &&
                       resource.data.contributors.hasAny([request.auth.uid]) &&
                       (request.resource.data.contributors == null ||
                        !request.resource.data.contributors.hasAny([request.auth.uid])) &&
                       request.resource.data.ownerId == resource.data.ownerId &&
                       request.resource.data.name == resource.data.name &&
                       request.resource.data.avatar == resource.data.avatar)
                    );
      
      // Only owner can delete child
      allow delete: if request.auth != null &&
                      resource.data.ownerId == request.auth.uid;
      
      // Memories subcollection
      match /memories/{memoryId} {
        // Anyone with child access can read memories
        allow read: if request.auth != null && hasChildAccess(childId);
        
        // Anyone with child access can create memories
        allow create: if request.auth != null && 
                        hasChildAccess(childId) &&
                        request.resource.data.authorId == request.auth.uid;
        
        // Author or child owner can update memories
        allow update: if request.auth != null && (
                        resource.data.authorId == request.auth.uid ||
                        get(/databases/$(database)/documents/children/$(childId)).data.ownerId == request.auth.uid
                      );
        
        // Author or child owner can delete memories
        allow delete: if request.auth != null && (
                        resource.data.authorId == request.auth.uid ||
                        get(/databases/$(database)/documents/children/$(childId)).data.ownerId == request.auth.uid
                      );
      }
    }
    
    // Users collection
    match /users/{userId} {
      // Users can read their own document or other users' documents (needed for contributor lists)
      // Write operations are still restricted to own document only
      allow read: if request.auth != null;
      // Users can only write their own document
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Invitations collection
    match /invitations/{invitationId} {
      // Anyone authenticated can read invitations
      allow read: if request.auth != null;
      
      // Anyone authenticated can create invitations
      allow create: if request.auth != null;
      
      // Anyone authenticated can update invitations (for accepting/declining)
      allow update: if request.auth != null;
      
      // Only creator can delete invitation
      allow delete: if request.auth != null &&
                      resource.data.inviterUserId == request.auth.uid;
    }
    
    // Monthly Summaries collection (tracks sent summaries)
    match /monthlySummaries/{summaryId} {
      // Users can read their own summary records
      // Allow read if document doesn't exist (for checking) OR if it exists and belongs to user
      allow read: if request.auth != null &&
                    (!resource.exists || resource.data.userId == request.auth.uid);
      
      // Users can create summary records for their own children
      allow create: if request.auth != null &&
                      request.resource.data.userId == request.auth.uid;
      
      // Users can update their own summary records (to mark as sent)
      allow update: if request.auth != null &&
                      resource.data.userId == request.auth.uid;
      
      // Users can delete their own summary records (optional cleanup)
      allow delete: if request.auth != null &&
                      resource.data.userId == request.auth.uid;
    }
    
    // LEGACY: Old user-based children (for backward compatibility during migration)
    // Can be removed after all users have migrated
    match /users/{userId}/children/{childId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    match /users/{userId}/memories/{memoryId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}

